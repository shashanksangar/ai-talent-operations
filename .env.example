# Environment variables for AI Talent Operations

# Logging
LOG_LEVEL=INFO

# Sourcing Agent
SOURCING_AGENT_URL=http://localhost:5000/api
SOURCING_AGENT_ENABLED=true

# Matching Agent
MATCHING_AGENT_URL=http://localhost:5001/api
MATCHING_AGENT_ENABLED=true

# Outreach Agent
OUTREACH_AGENT_URL=http://localhost:5002/api
OUTREACH_AGENT_ENABLED=true

# Workflow Configuration
WORKFLOW_BATCH_SIZE=50
WORKFLOW_PARALLEL_PROCESSING=true
WORKFLOW_RETRY_ATTEMPTS=3

# Output
OUTPUT_DIRECTORY=./results
LOG_DIRECTORY=./logs
